# FocusFlow AI — Environment Configuration Reference
#
# This file documents all environment variables used across the project.
# Copy the relevant section to the appropriate .env file in each sub-directory.

# ── Backend (copy to backend/.env) ───────────────────────────────────────────

PORT=5000
HOST=0.0.0.0
DB_PATH=./data/focusflow.db

# REQUIRED: generate a strong random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret

JWT_EXPIRE=7d
NODE_ENV=development

# Allowed CORS origin when NODE_ENV=production
FRONTEND_URL=http://localhost:8080

# ── Frontend (copy to frontend/.env.local) ───────────────────────────────────
#
# Web browser and Android emulator:
EXPO_PUBLIC_API_URL=http://localhost:5000/api/v1
#
# Physical device on same Wi-Fi (replace with your PC's local IP):
# EXPO_PUBLIC_API_URL=http://192.168.x.x:5000/api/v1
#
# NOTE: When running via Expo Go on a physical device, the frontend
# auto-detects the backend IP from the Expo dev-server host —
# you typically do not need to set this manually.
