# FocusFlow AI Backend Environment Configuration
# 
# PORT: The port the backend server will listen on
# Default: 5000
PORT=5000

# HOST: The network interface to bind to
# 0.0.0.0 = Listen on all interfaces (required for external connections)
# localhost = Only local connections
# Default: 0.0.0.0
HOST=0.0.0.0

# DATABASE
DB_PATH=./data/focusflow.db

# SECURITY - JWT Configuration
# JWT_SECRET: A secure secret key for JWT token signing
#   IMPORTANT: Change this to a strong random string in production!
#   Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=focusflow_jwt_s3cr3t_k3y_2025_x9z!@#$%^&*()_ultra_secure

# JWT_EXPIRE: Token expiration time
JWT_EXPIRE=7d

# NODE_ENV: Environment mode
# development = Enable request logging, detailed error messages
# production = Disable request logging, simplified error messages
NODE_ENV=development

# FRONTEND_URL: URL of the frontend application (used for CORS)
# For development, include all possible frontend URLs
# For production, specify only your actual frontend URLs
FRONTEND_URL=http://localhost:8080

# Additional CORS origins are configured in server.js
# They include:
#  - localhost:8081 (Expo web)
#  - localhost:19006 (Expo web alternate)
#  - 192.168.*.* (Local network devices)
#  - 10.0.*.* (Android emulator)
#  - exp:// (Expo Go scheme)
