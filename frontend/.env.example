# FocusFlow AI Frontend Environment Configuration
# Copy this file to .env.local and configure for your environment
# 
# API URL Configuration Guide:
# ======================================================================
#
# 1. LOCAL DEVELOPMENT (same machine):
#    EXPO_PUBLIC_API_URL=http://localhost:5000/api/v1
#
# 2. ANDROID EMULATOR (from Windows/Mac/Linux):
#    EXPO_PUBLIC_API_URL=http://10.0.2.2:5000/api/v1
#    (Auto-detected when running on Android emulator)
#
# 3. iOS SIMULATOR (from Mac):
#    EXPO_PUBLIC_API_URL=http://localhost:5000/api/v1
#    (Auto-detected when running on iOS simulator)
#
# 4. PHYSICAL DEVICE ON LOCAL NETWORK:
#    EXPO_PUBLIC_API_URL=http://192.168.X.X:5000/api/v1
#    Replace 192.168.X.X with your PC's IP address
#    Find your IP with:
#      - Windows: ipconfig (look for IPv4 Address)
#      - Mac/Linux: ifconfig or ip addr
#
# 5. EXPO GO APP:
#    EXPO_PUBLIC_API_URL=http://<YOUR_PC_IP>:5000/api/v1
#    Replace <YOUR_PC_IP> with your development machine's local IP
#
# ======================================================================

# Configure this for your environment:
EXPO_PUBLIC_API_URL=http://localhost:5000/api/v1
